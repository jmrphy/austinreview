---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="The Austin Review">
  <main>
    <!-- Hero -->
    <section class="hero">
      <h1 class="masthead">The Austin Review</h1>
      <p class="tagline">Letters and conversations from Austin, Texas</p>
      <form
        class="subscribe-form"
        action="https://buttondown.com/api/emails/embed-subscribe/user0834"
        method="post"
        target="_blank"
      >
        <input type="email" name="email" placeholder="Your email" required />
        <button type="submit">Subscribe</button>
      </form>
    </section>

    <!-- Archive -->
    <section class="archive">
      <p class="section-label">Recent Issues</p>
      <ul class="archive-list" id="archive-list">
        <li class="archive-loading"><span class="archive-date">Loading issues...</span></li>
      </ul>
    </section>

    <!-- Podcast -->
    <section class="podcast">
      <p class="section-label">Podcast</p>
      <iframe
        src="https://share.transistor.fm/e/austin-review/playlist"
        width="100%"
        height="390"
        frameborder="no"
        scrolling="no"
        seamless
      ></iframe>
      <a class="podcast-link" href="https://feeds.transistor.fm/austin-review">RSS Feed &rarr;</a>
    </section>

    <!-- Footer -->
    <footer>
      <p>&copy; {new Date().getFullYear()} The Austin Review</p>
    </footer>
  </main>
</BaseLayout>

<script>
  const fallback = `<li><a href="https://buttondown.com/user0834/archive/">Browse the archive</a><span class="archive-date">Issues published weekly</span></li>`;

  async function loadIssues() {
    const list = document.getElementById('archive-list');
    if (!list) return;

    try {
      const res = await fetch('/api/issues.json');
      if (!res.ok) { list.innerHTML = fallback; return; }

      const { results } = await res.json();
      if (!results || results.length === 0) { list.innerHTML = fallback; return; }

      list.innerHTML = results
        .map((email: { absolute_url: string; subject: string; publish_date: string }) => {
          const date = new Date(email.publish_date).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return `<li>
            <a href="${email.absolute_url}">${email.subject}</a>
            <span class="archive-date">${date}</span>
          </li>`;
        })
        .join('');
    } catch {
      list.innerHTML = fallback;
    }
  }

  loadIssues();
</script>
